{
  "name": "insightx-analytics",
  "version": "1.0.0",
  "description": "Conversational AI for Payment Transaction Analytics",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "electron",
    "ai",
    "analytics",
    "payments"
  ],
  "author": "Your Name",
  "license": "MIT",
  "build": {
    "appId": "com.insightx.analytics",
    "productName": "InsightX Analytics",
    "directories": {
      "output": "release"
    },
    "files": [
      "**/*",
      "!backend/**/*",
      "!release/**/*",
      "!dist/**/*",
      "!.git/**/*",
      "!*.md",
      "!*.bat"
    ],
    "extraResources": [
      {
        "from": "backend/dist/api_server.exe",
        "to": "backend/dist/api_server.exe"
      },
      {
        "from": "backend/data",
        "to": "backend/data",
        "filter": ["**/*"]
      },
      {
        "from": "backend/.env",
        "to": "backend/.env"
      }
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "chart.js": "^4.4.0",
    "date-fns": "^2.30.0"
  }
}
