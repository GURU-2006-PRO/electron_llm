# ===== API KEYS - KEEP SECRET =====
# Get your API keys from:
# - OpenRouter: https://openrouter.ai/keys
# - Gemini: https://aistudio.google.com/app/apikey
# - Groq: https://console.groq.com/keys

# OpenRouter (DeepSeek models) - Optional fallback
OPENROUTER_API_KEY=your-openrouter-key-here

# Google Gemini API Keys (3 keys for different models)
# Gemini 3.0 Flash Preview (Primary - 20 req/day)
GEMINI_API_KEY_3_FLASH=your-gemini-3-flash-key-here

# Gemini 2.5 Flash (Fallback 1 - 1500 req/day)
GEMINI_API_KEY_2_5_FLASH_1=your-gemini-2.5-flash-key-1-here

# Gemini 2.5 Flash (Fallback 2 - 1500 req/day)
GEMINI_API_KEY_2_5_FLASH_2=your-gemini-2.5-flash-key-2-here

# Groq (Fast inference - 500K free tokens/day)
GROQ_API_KEY=your-groq-key-here

# ===== DATABASE SETTINGS =====
DATABASE_PATH=data/chat_history.db

# ===== SERVER SETTINGS =====
FLASK_DEBUG=True
FLASK_PORT=5000
FLASK_HOST=127.0.0.1

# ===== INSTRUCTIONS =====
# 1. Copy this file to .env (or rename it to .env)
# 2. Replace all "your-*-key-here" with your actual API keys
# 3. Get Gemini API keys from: https://aistudio.google.com/app/apikey
# 4. IMPORTANT: Generate 3 DIFFERENT Gemini keys for redundancy
# 5. Never commit .env file to version control (already in .gitignore)
# 6. After updating keys, restart the backend server
